{
  "name": "@saas-template/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "browser": false,
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "nero": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@saas-template/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "cli",
    "tags": [
      "type:package",
      "scope:cli",
      "platform:node"
    ],
    "targets": {
      "test": {
        "dependsOn": [
          "^build"
        ],
        "options": {
          "passWithNoTests": false
        }
      }
    }
  },
  "dependencies": {
    "@saas-template/config": "workspace:*",
    "@saas-template/shared": "workspace:*",
    "@saas-template/validation": "workspace:*",
    "jiti": "2.7.0",
    "tslib": "^2.3.0"
  }
}
