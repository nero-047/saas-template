# Server-only runtime variables. Copy to apps/api/.env.local for Nx development.
DATABASE_URL=postgresql://saas_template:local_development_only@127.0.0.1:5432/saas_template

# Required only when this process enqueues background work.
REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_PREFIX=saas-template

# Optional process setting; defaults to 3000.
PORT=3000

# Opaque session cookie settings. Production defaults SESSION_COOKIE_SECURE to true.
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_SECONDS=2592000
