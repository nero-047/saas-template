FROM docker.io/node:24-alpine

ENV PORT=3000


WORKDIR /app

COPY dist .

# You can remove this install step if you build with `--bundle` option.
# The bundled output will include external dependencies.

RUN corepack enable \
    && corepack install --global pnpm@11.10.0 \
    && pnpm install --prod --frozen-lockfile --force

USER node

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD ["node", "-e", "fetch('http://127.0.0.1:' + (process.env.PORT || '3000') + '/health', { signal: AbortSignal.timeout(2000) }).then((response) => { if (!response.ok) process.exit(1); }).catch(() => process.exit(1))"]

CMD [ "node", "main.js" ]
